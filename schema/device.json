{
    "$schema": "https://json-schema.org/draft/2019-09/schema",
    "$id": "https://harp-tech.org/draft-03/schema/device.json",
    "type": "object",
    "allOf": [
        {
            "properties": {
                "device": {
                    "description": "Specifies the name of the device.",
                    "type": "string"
                },
                "whoAmI": {
                    "description": "Specifies the unique identifier for this device type.",
                    "type": "integer"
                },
                "firmwareVersion": {
                    "description": "Specifies the version of the device firmware.",
                    "$ref": "core.json#/$defs/version"
                },
                "hardwareTargets": {
                    "description": "Specifies the version of the hardware targets.",
                    "oneOf": [
                        { "$ref": "core.json#/$defs/version" },
                        {
                    "type": "array",
                            "items": { "$ref": "core.json#/$defs/version" },
                            "uniqueItems": true,
                            "minItems": 1
                    }
                    ]
                },
                "registers": {
                    "additionalProperties": {
                        "properties": {
                            "address": { "minimum": 32 }
                        }
                    }
                }
            },
            "required": ["device", "whoAmI", "firmwareVersion", "hardwareTargets"]
        },
        { "$ref": "core.json" }
    ]
}